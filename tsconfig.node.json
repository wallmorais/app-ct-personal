{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "outDir": "node_modules/.tsbuild-node",
    "tsBuildInfoFile": "node_modules/.tsbuild-node/tsconfig.node.tsbuildinfo"
  },
  "include": ["vite.config.ts"]
}
